    "ai": "^4.3.0",
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "figlet": "^1.11.0",
    "grammy": "^1.42.0",
    "ink": "^5.2.0",
    "js-tiktoken": "^1.0.19",
    "marked": "^14.1.4",
